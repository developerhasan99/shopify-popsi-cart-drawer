{% liquid
  assign current_product_id = ''
  if product
    assign current_product_id = product.id
  endif

  assign shop_domain = shop.permanent_domain
%}

<popsi-cart-drawer
  data-block-id="{{ block.id }}"
  data-script-src="{{ 'popsi-cart-drawer.js' | asset_url }}"
  data-current-product-id="{{ current_product_id }}"
  data-shop-domain="{{ shop_domain }}"
  data-app-url="{{ request.host }}"></popsi-cart-drawer>

{% schema %}
{
  "name": "Cart drawer",
  "target": "body",
  "stylesheet": "popsi-cart-drawer.css",
  "javascript": "popsi-cart-loader.js",
  "settings": []
}
{% endschema %}