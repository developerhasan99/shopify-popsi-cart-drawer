{% liquid
  assign trust_badge_url = 'payment-badge.svg' | asset_url
  if block.settings.trust_badge_image != blank
    assign trust_badge_url = block.settings.trust_badge_image | image_url: width: 700
  endif

  assign current_product_id = ''
  if product
    assign current_product_id = product.id
  endif
%}

<popsi-cart-drawer
  data-block-id="{{ block.id }}"
  data-script-src="{{ 'popsi-cart-drawer.js' | asset_url }}"
  data-current-product-id="{{ current_product_id }}"
  data-auto-open-cart="{{ block.settings.auto_open_cart }}"
  data-show-floating-trigger="{{ block.settings.show_floating_trigger }}"
  data-floating-position="{{ block.settings.floating_position }}"
  data-inherit-fonts="{{ block.settings.inherit_fonts }}"
  data-cart-title="{{ block.settings.cart_title | escape }}"
  data-show-cart-count="{{ block.settings.show_cart_count }}"
  data-cart-icon-type="{{ block.settings.cart_icon_type }}"
  data-cart-icon-color="{{ block.settings.cart_icon_color }}"
  data-cart-icon-size="{{ block.settings.cart_icon_size }}"
  data-cart-bubble-bg="{{ block.settings.cart_bubble_bg }}"
  data-cart-bubble-text="{{ block.settings.cart_bubble_text }}"
  data-bg-color="{{ block.settings.bg_color }}"
  data-text-color="{{ block.settings.text_color }}"
  data-accent-color="{{ block.settings.accent_color }}"
  data-btn-color="{{ block.settings.btn_color }}"
  data-btn-text-color="{{ block.settings.btn_text_color }}"
  data-btn-hover-color="{{ block.settings.btn_hover_color }}"
  data-btn-hover-text-color="{{ block.settings.btn_hover_text_color }}"
  data-btn-radius="{{ block.settings.btn_radius }}"
  data-show-announcement="{{ block.settings.show_announcement }}"
  data-announcement-text="{{ block.settings.announcement_text | escape }}"
  data-announcement-bg="{{ block.settings.announcement_bg }}"
  data-announcement-text-color="{{ block.settings.announcement_text_color }}"
  data-announcement-size="{{ block.settings.announcement_bar_size }}"
  data-timer-duration="{{ block.settings.timer_duration }}"
  data-enable-rewards-bar="{{ block.settings.enable_rewards_bar }}"
  data-show-rewards-on-empty="{{ block.settings.show_rewards_on_empty }}"
  data-reward-type="{{ block.settings.reward_type }}"
  data-reward-away-text="{{ block.settings.reward_away_text | escape }}"
  data-reward-completed-text="{{ block.settings.reward_completed_text | escape }}"
  data-reward-goal-one-threshold="{{ block.settings.reward_goal_one_threshold }}"
  data-reward-goal-one-label="{{ block.settings.reward_goal_one_label | escape }}"
  data-reward-goal-one-icon="{{ block.settings.reward_goal_one_icon }}"
  data-reward-goal-two-threshold="{{ block.settings.reward_goal_two_threshold }}"
  data-reward-goal-two-label="{{ block.settings.reward_goal_two_label | escape }}"
  data-reward-goal-two-icon="{{ block.settings.reward_goal_two_icon }}"
  data-rewards-bar-bg="{{ block.settings.rewards_bar_bg }}"
  data-rewards-bar-fg="{{ block.settings.rewards_bar_fg }}"
  data-rewards-complete-icon-color="{{ block.settings.rewards_complete_icon_color }}"
  data-rewards-incomplete-icon-color="{{ block.settings.rewards_incomplete_icon_color }}"
  data-show-item-images="{{ block.settings.show_item_images }}"
  data-show-strikethrough="{{ block.settings.show_strikethrough }}"
  data-show-savings="{{ block.settings.show_savings }}"
  data-savings-text-color="{{ block.settings.savings_text_color }}"
  data-savings-prefix="{{ block.settings.trans_savings_prefix | escape }}"
  data-enable-coupon="{{ block.settings.enable_coupon }}"
  data-enable-subtotal-line="{{ block.settings.enable_subtotal_line }}"
  data-enable-total-line="{{ block.settings.enable_total_line }}"
  data-show-shipping-notice="{{ block.settings.show_shipping_notice }}"
  data-show-subtotal-on-checkout="{{ block.settings.show_subtotal_on_checkout }}"
  data-show-upsells="{{ block.settings.show_upsells }}"
  data-show-upsells-on-empty="{{ block.settings.show_upsells_on_empty }}"
  data-upsell-title="{{ block.settings.upsell_title | escape }}"
  data-upsell-max="{{ block.settings.upsell_max }}"
  data-upsell-intent="{{ block.settings.upsell_intent }}"
  data-upsell-btn-text="{{ block.settings.upsell_btn_text | escape }}"
  data-show-trust-badges="{{ block.settings.show_trust_badges }}"
  data-trust-badge-url="{{ trust_badge_url }}"
  data-trans-checkout-btn="{{ block.settings.trans_checkout_btn | escape }}"
  data-trans-continue-shopping="{{ block.settings.trans_continue_shopping | escape }}"
  data-trans-empty-cart="{{ block.settings.trans_empty_cart | escape }}"
  data-trans-subtotal="{{ block.settings.trans_subtotal | escape }}"
  data-trans-total="{{ block.settings.trans_total | escape }}"
  data-trans-discounts="{{ block.settings.trans_discounts | escape }}"
  data-trans-coupon-accordion-title="{{ block.settings.trans_coupon_accordion_title | escape }}"
  data-trans-coupon-placeholder="{{ block.settings.trans_coupon_placeholder | escape }}"
  data-trans-coupon-apply-btn="{{ block.settings.trans_coupon_apply_btn | escape }}"
  data-shipping-notice-text="{{ block.settings.shipping_notice_text | escape }}"
></popsi-cart-drawer>

{% schema %}
{
  "name": "Cart drawer",
  "target": "body",
  "stylesheet": "popsi-cart-drawer.css",
  "javascript": "popsi-cart-loader.js",
  "settings": [
    {
      "type": "header",
      "content": "Behavior"
    },
    {
      "type": "checkbox",
      "id": "auto_open_cart",
      "label": "Open drawer after add to cart",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_floating_trigger",
      "label": "Show floating cart icon",
      "default": true
    },
    {
      "type": "select",
      "id": "floating_position",
      "label": "Floating icon position",
      "default": "bottom-right",
      "options": [
        { "value": "bottom-right", "label": "Bottom right" },
        { "value": "bottom-left", "label": "Bottom left" }
      ]
    },
    {
      "type": "checkbox",
      "id": "inherit_fonts",
      "label": "Inherit theme fonts",
      "default": true
    },
    {
      "type": "header",
      "content": "Cart icon"
    },
    {
      "type": "select",
      "id": "cart_icon_type",
      "label": "Icon",
      "default": "bag-1",
      "options": [
        { "value": "bag-1", "label": "Bag 1" },
        { "value": "bag-2", "label": "Bag 2" },
        { "value": "cart", "label": "Cart" },
        { "value": "basket", "label": "Basket" }
      ]
    },
    {
      "type": "color",
      "id": "cart_icon_color",
      "label": "Icon color",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "cart_icon_size",
      "label": "Icon size",
      "min": 18,
      "max": 36,
      "step": 1,
      "unit": "px",
      "default": 24
    },
    {
      "type": "checkbox",
      "id": "show_cart_count",
      "label": "Show cart count",
      "default": true
    },
    {
      "type": "color",
      "id": "cart_bubble_bg",
      "label": "Count bubble background",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "cart_bubble_text",
      "label": "Count bubble text",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Drawer design"
    },
    {
      "type": "text",
      "id": "cart_title",
      "label": "Cart title",
      "default": "Your Cart"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent background",
      "default": "#f6f6f7"
    },
    {
      "type": "color",
      "id": "btn_color",
      "label": "Button background",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "btn_text_color",
      "label": "Button text",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "btn_hover_color",
      "label": "Button hover background",
      "default": "#333333"
    },
    {
      "type": "color",
      "id": "btn_hover_text_color",
      "label": "Button hover text",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "btn_radius",
      "label": "Button radius",
      "min": 0,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 5
    },
    {
      "type": "header",
      "content": "Announcement"
    },
    {
      "type": "checkbox",
      "id": "show_announcement",
      "label": "Show announcement bar",
      "default": false
    },
    {
      "type": "textarea",
      "id": "announcement_text",
      "label": "Announcement text",
      "default": "Your products are reserved for {timer}!"
    },
    {
      "type": "select",
      "id": "announcement_bar_size",
      "label": "Announcement size",
      "default": "medium",
      "options": [
        { "value": "small", "label": "Small" },
        { "value": "medium", "label": "Medium" },
        { "value": "large", "label": "Large" }
      ]
    },
    {
      "type": "range",
      "id": "timer_duration",
      "label": "Timer duration",
      "min": 1,
      "max": 60,
      "step": 1,
      "unit": "min",
      "default": 15
    },
    {
      "type": "color",
      "id": "announcement_bg",
      "label": "Announcement background",
      "default": "#fffbeb"
    },
    {
      "type": "color",
      "id": "announcement_text_color",
      "label": "Announcement text",
      "default": "#92400e"
    },
    {
      "type": "header",
      "content": "Rewards"
    },
    {
      "type": "checkbox",
      "id": "enable_rewards_bar",
      "label": "Show rewards progress",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_rewards_on_empty",
      "label": "Show rewards when cart is empty",
      "default": true
    },
    {
      "type": "select",
      "id": "reward_type",
      "label": "Reward progress type",
      "default": "subtotal",
      "options": [
        { "value": "subtotal", "label": "Cart subtotal" },
        { "value": "quantity", "label": "Item quantity" }
      ]
    },
    {
      "type": "text",
      "id": "reward_away_text",
      "label": "Away text",
      "default": "You're only {amount} away from {goal}"
    },
    {
      "type": "text",
      "id": "reward_completed_text",
      "label": "Completed text",
      "default": "Congratulations! You have unlocked all rewards."
    },
    {
      "type": "range",
      "id": "reward_goal_one_threshold",
      "label": "First goal threshold",
      "min": 5,
      "max": 500,
      "step": 5,
      "default": 50
    },
    {
      "type": "text",
      "id": "reward_goal_one_label",
      "label": "First goal label",
      "default": "Free Shipping"
    },
    {
      "type": "select",
      "id": "reward_goal_one_icon",
      "label": "First goal icon",
      "default": "truck",
      "options": [
        { "value": "truck", "label": "Truck" },
        { "value": "tag", "label": "Tag" },
        { "value": "gift", "label": "Gift" },
        { "value": "star", "label": "Star" }
      ]
    },
    {
      "type": "range",
      "id": "reward_goal_two_threshold",
      "label": "Second goal threshold",
      "min": 5,
      "max": 500,
      "step": 5,
      "default": 100
    },
    {
      "type": "text",
      "id": "reward_goal_two_label",
      "label": "Second goal label",
      "default": "10% Discount"
    },
    {
      "type": "select",
      "id": "reward_goal_two_icon",
      "label": "Second goal icon",
      "default": "tag",
      "options": [
        { "value": "truck", "label": "Truck" },
        { "value": "tag", "label": "Tag" },
        { "value": "gift", "label": "Gift" },
        { "value": "star", "label": "Star" }
      ]
    },
    {
      "type": "color",
      "id": "rewards_bar_bg",
      "label": "Progress background",
      "default": "#e2e2e2"
    },
    {
      "type": "color",
      "id": "rewards_bar_fg",
      "label": "Progress fill",
      "default": "#93d3ff"
    },
    {
      "type": "color",
      "id": "rewards_complete_icon_color",
      "label": "Completed icon color",
      "default": "#4d4949"
    },
    {
      "type": "color",
      "id": "rewards_incomplete_icon_color",
      "label": "Incomplete icon color",
      "default": "#4d4949"
    },
    {
      "type": "header",
      "content": "Cart content"
    },
    {
      "type": "checkbox",
      "id": "show_item_images",
      "label": "Show item images",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_strikethrough",
      "label": "Show compare-at prices",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_savings",
      "label": "Show savings text",
      "default": true
    },
    {
      "type": "color",
      "id": "savings_text_color",
      "label": "Savings text color",
      "default": "#2ea818"
    },
    {
      "type": "text",
      "id": "trans_savings_prefix",
      "label": "Savings prefix",
      "default": "Save"
    },
    {
      "type": "checkbox",
      "id": "enable_coupon",
      "label": "Show discount code field",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "enable_subtotal_line",
      "label": "Show subtotal",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "enable_total_line",
      "label": "Show total",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_shipping_notice",
      "label": "Show shipping notice",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_subtotal_on_checkout",
      "label": "Show total on checkout button",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_upsells",
      "label": "Show product recommendations",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_upsells_on_empty",
      "label": "Show recommendations on empty cart",
      "default": true
    },
    {
      "type": "text",
      "id": "upsell_title",
      "label": "Recommendations title",
      "default": "You might also like..."
    },
    {
      "type": "range",
      "id": "upsell_max",
      "label": "Maximum recommendations",
      "min": 1,
      "max": 10,
      "step": 1,
      "default": 3
    },
    {
      "type": "select",
      "id": "upsell_intent",
      "label": "Recommendation intent",
      "default": "related",
      "options": [
        { "value": "related", "label": "Related" },
        { "value": "complementary", "label": "Complementary" }
      ]
    },
    {
      "type": "text",
      "id": "upsell_btn_text",
      "label": "Upsell button text",
      "default": "Add to Cart"
    },
    {
      "type": "checkbox",
      "id": "show_trust_badges",
      "label": "Show payment badges",
      "default": true
    },
    {
      "type": "image_picker",
      "id": "trust_badge_image",
      "label": "Payment badge image"
    },
    {
      "type": "text",
      "id": "trans_checkout_btn",
      "label": "Checkout button",
      "default": "Checkout"
    },
    {
      "type": "text",
      "id": "trans_continue_shopping",
      "label": "Continue shopping",
      "default": "Continue Shopping"
    },
    {
      "type": "text",
      "id": "trans_empty_cart",
      "label": "Empty cart text",
      "default": "Your cart is currently empty."
    },
    {
      "type": "text",
      "id": "trans_subtotal",
      "label": "Subtotal",
      "default": "Subtotal"
    },
    {
      "type": "text",
      "id": "trans_total",
      "label": "Total",
      "default": "Total"
    },
    {
      "type": "text",
      "id": "trans_discounts",
      "label": "Discounts",
      "default": "Discounts"
    },
    {
      "type": "text",
      "id": "trans_coupon_accordion_title",
      "label": "Discount accordion title",
      "default": "Have a Coupon?"
    },
    {
      "type": "text",
      "id": "trans_coupon_placeholder",
      "label": "Discount placeholder",
      "default": "Coupon code"
    },
    {
      "type": "text",
      "id": "trans_coupon_apply_btn",
      "label": "Discount apply button",
      "default": "Apply"
    },
    {
      "type": "text",
      "id": "shipping_notice_text",
      "label": "Shipping notice",
      "default": "Shipping and taxes will be calculated at checkout."
    }
  ]
}
{% endschema %}
